# StakeSignal crank — Pyth resolver + market creator + yield calculator
# Used by all three Python entry points in this directory.

# Solana
ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
PROGRAM_ID=2WNxCQG7khECic8tNgWwPgEtEkVKrXhn9b5pSdKfR35b

# Crank wallet — provide ONE of:
#   CRANK_KEYPAIR_JSON: full secret as JSON array of 64 ints, e.g. [12,34,...]
#   CRANK_KEYPAIR_PATH: filesystem path to id.json (local dev)
CRANK_KEYPAIR_JSON=
CRANK_KEYPAIR_PATH=./crank-keypair.json

# Schedule
RESOLVE_CHECK_INTERVAL_MINUTES=10

# Pyth Hermes
PYTH_HERMES_URL=https://hermes.pyth.network

# Optional: for enhanced RPC (DAS, getAsset, etc.)
HELIUS_API_KEY=

# LST mints (devnet defaults — override only if mocked elsewhere)
MSOL_MINT=mSoLzYCxHdYgdzU16g5QSh3i5K3z3KZK7ytfqcJm7So
JITOSOL_MINT=J1toso1uCk3RLmjorhTtrVwY9HJ7X8V9yYac6Y7kGCPn
