# StakeSignal — Environment Variables
# copy to `.env` for crank/anchor and `web/.env.local` for frontend

# Anchor
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
PROGRAM_ID=

# RPC — Helius gives the most stable devnet throughput
# free key at https://dev.helius.xyz
HELIUS_API_KEY=

# Pyth — Hermes is the public price-streaming endpoint
PYTH_HERMES_URL=https://hermes.pyth.network

# LST mints — used as collateral acceptance list
MSOL_MINT=mSoLzYCxHdYgdzU16g5QSh3i5K3z3KZK7ytfqcJm7So
JITOSOL_MINT=J1toso1uCk3RLmjorhTtrVwY9HJ7X8V9yYac6Y7kGCPn

# Frontend (Next.js — anything VITE/NEXT_PUBLIC is shipped to the browser)
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_PROGRAM_ID=

# Crank — resolver loop interval and signing keypair
CRANK_KEYPAIR_PATH=./crank-keypair.json
RESOLVE_CHECK_INTERVAL_MINUTES=10
